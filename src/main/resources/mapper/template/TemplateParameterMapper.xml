<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateParameterMapper">

    <!-- 
        文件位置：src/main/resources/mapper/template/TemplateParameterMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplateParameterMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplateParameter">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="param_type" property="paramType"/>
        <result column="param_name" property="paramName"/>
        <result column="param_value" property="paramValue"/>
        <result column="data_type" property="dataType"/>
        <result column="description" property="description"/>
        <result column="example_value" property="exampleValue"/>
        <result column="is_required" property="isRequired"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="is_variable" property="isVariable"/>
        <result column="variable_name" property="variableName"/>
        <result column="validation_rules" property="validationRules"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据模板ID查询参数列表 -->
    <select id="selectByTemplateId" resultMap="BaseResultMap">
        SELECT * FROM template_parameter 
        WHERE template_id = #{templateId} 
--         AND is_enabled = 1
        ORDER BY sort_order ASC
    </select>

    <!-- 根据模板ID和参数类型查询参数列表 -->
    <select id="selectByTemplateIdAndType" resultMap="BaseResultMap">
        SELECT * FROM template_parameter
        WHERE template_id = #{templateId}
        AND param_type = #{paramType}
        AND is_enabled = 1
        ORDER BY sort_order ASC
    </select>

    <!-- 批量插入参数 -->
    <insert id="batchInsert">
        INSERT INTO template_parameter (
            template_id, param_type, param_name, param_value, data_type,
            description, example_value, is_required, is_enabled, is_variable,
            variable_name, validation_rules, sort_order
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.templateId}, #{item.paramType}, #{item.paramName}, #{item.paramValue}, #{item.dataType},
                #{item.description}, #{item.exampleValue}, #{item.isRequired}, #{item.isEnabled}, #{item.isVariable},
                #{item.variableName}, #{item.validationRules}, #{item.sortOrder}
            )
        </foreach>
    </insert>

</mapper>
