<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateFolderMapper">

    <!-- 
        文件位置：src/main/resources/mapper/template/TemplateFolderMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplateFolderMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplateFolder">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="icon" property="icon"/>
        <result column="color" property="color"/>

        <result column="team_id" property="teamId"/>
        <result column="visibility" property="visibility"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted_time" property="deletedTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, parent_id, name, description, sort_order, icon, color,
        team_id, visibility, status,
        create_time, update_time, deleted_time
    </sql>

</mapper>
