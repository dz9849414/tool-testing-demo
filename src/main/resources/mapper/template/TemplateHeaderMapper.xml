<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateHeaderMapper">

    <!-- 
        文件位置：src/main/resources/mapper/template/TemplateHeaderMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplateHeaderMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplateHeader">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="header_name" property="headerName"/>
        <result column="header_value" property="headerValue"/>
        <result column="description" property="description"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="is_required" property="isRequired"/>
        <result column="is_variable" property="isVariable"/>
        <result column="variable_name" property="variableName"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据模板ID查询请求头列表 -->
    <select id="selectByTemplateId" resultMap="BaseResultMap">
        SELECT * FROM template_header 
        WHERE template_id = #{templateId} 
        AND is_enabled = 1 
        ORDER BY sort_order ASC
    </select>

    <!-- 批量插入请求头 -->
    <insert id="batchInsert">
        INSERT INTO template_header (
            template_id, header_name, header_value, description,
            is_enabled, is_required, is_variable, variable_name, sort_order
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.templateId}, #{item.headerName}, #{item.headerValue}, #{item.description},
                #{item.isEnabled}, #{item.isRequired}, #{item.isVariable}, #{item.variableName}, #{item.sortOrder}
            )
        </foreach>
    </insert>

</mapper>
