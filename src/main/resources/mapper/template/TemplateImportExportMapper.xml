<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateImportExportMapper">

    <!--
        文件位置：src/main/resources/mapper/template/TemplateImportExportMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplateImportExportMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplateImportExport">
        <id column="id" property="id"/>
        <result column="operation_type" property="operationType"/>
        <result column="template_ids" property="templateIds"/>
        <result column="folder_id" property="folderId"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_format" property="fileFormat"/>
        <result column="status" property="status"/>
        <result column="success_count" property="successCount"/>
        <result column="fail_count" property="failCount"/>
        <result column="error_message" property="errorMessage"/>
        <result column="create_id" property="createId"/>
        <result column="create_name" property="createName"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 查询指定操作类型的记录 -->
    <select id="selectByOperationType" resultMap="BaseResultMap">
        SELECT * FROM pdm_tool_template_import_export
        WHERE operation_type = #{operationType}
        ORDER BY create_time DESC
        <if test="limit != null">
            LIMIT #{limit}
        </if>
    </select>
</mapper>
