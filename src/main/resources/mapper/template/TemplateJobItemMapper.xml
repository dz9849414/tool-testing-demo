<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateJobItemMapper">

    <select id="selectByJobId" resultType="com.example.tooltestingdemo.entity.template.TemplateJobItem">
        SELECT * FROM pdm_tool_template_job_item
        WHERE job_id = #{jobId}
        AND (is_deleted = 0 OR is_deleted IS NULL)
        AND (status IS NULL OR status = 1)
        ORDER BY sort_order ASC, id ASC
    </select>

    <delete id="deleteByJobId">
        DELETE FROM pdm_tool_template_job_item WHERE job_id = #{jobId}
    </delete>

</mapper>

