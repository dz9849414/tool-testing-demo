<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateHistoryMapper">

    <!-- 
        文件位置：src/main/resources/mapper/template/TemplateHistoryMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplateHistoryMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplateHistory">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="version" property="version"/>
        <result column="version_type" property="versionType"/>
        <result column="change_summary" property="changeSummary"/>
        <result column="change_details" property="changeDetails"/>
        <result column="template_snapshot" property="templateSnapshot"/>
        <result column="create_id" property="createId"/>
        <result column="create_name" property="createName"/>
        <result column="operation_type" property="operationType"/>
        <result column="can_rollback" property="canRollback"/>
        <result column="rollback_to_time" property="rollbackToTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 根据模板ID查询历史版本列表 -->
    <select id="selectByTemplateId" resultMap="BaseResultMap">
        SELECT * FROM template_history 
        WHERE template_id = #{templateId} 
        ORDER BY create_time DESC
    </select>

    <!-- 查询模板的最新版本 -->
    <select id="selectLatestByTemplateId" resultMap="BaseResultMap">
        SELECT * FROM template_history 
        WHERE template_id = #{templateId} 
        ORDER BY create_time DESC 
        LIMIT 1
    </select>

</mapper>
