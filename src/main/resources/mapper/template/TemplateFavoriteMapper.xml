<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplateFavoriteMapper">

    <!--
        文件位置：src/main/resources/mapper/template/TemplateFavoriteMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplateFavoriteMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplateFavorite">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="create_id" property="createId"/>
        <result column="favorite_type" property="favoriteType"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 根据用户ID和模板ID查询收藏记录 -->
    <select id="selectByUserAndTemplate" resultMap="BaseResultMap">
        SELECT * FROM pdm_tool_template_favorite
        WHERE create_id = #{userId}
        AND template_id = #{templateId}
    </select>

    <!-- 查询用户的收藏列表 -->
    <select id="selectFavoritesByUserId" resultMap="BaseResultMap">
        SELECT * FROM pdm_tool_template_favorite
        WHERE create_id = #{userId}
        AND favorite_type = 1
        ORDER BY create_time DESC
    </select>

    <!-- 查询用户的关注列表 -->
    <select id="selectFollowsByUserId" resultMap="BaseResultMap">
        SELECT * FROM pdm_tool_template_favorite
        WHERE create_id = #{userId}
        AND favorite_type = 2
        ORDER BY create_time DESC
    </select>

    <!-- 检查用户是否已收藏模板 -->
    <select id="checkFavoriteExists" resultType="int">
        SELECT COUNT(*) FROM pdm_tool_template_favorite
        WHERE create_id = #{userId}
        AND template_id = #{templateId}
        AND favorite_type = 1
    </select>
</mapper>
