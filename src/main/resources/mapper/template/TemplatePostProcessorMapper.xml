<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.template.TemplatePostProcessorMapper">

    <!--
        文件位置：src/main/resources/mapper/template/TemplatePostProcessorMapper.xml
        命名空间：com.example.tooltestingdemo.mapper.template.TemplatePostProcessorMapper
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.template.TemplatePostProcessor">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="processor_name" property="processorName"/>
        <result column="processor_type" property="processorType"/>
        <result column="extract_type" property="extractType"/>
        <result column="extract_expression" property="extractExpression"/>
        <result column="extract_match_no" property="extractMatchNo"/>
        <result column="target_variable" property="targetVariable"/>
        <result column="variable_scope" property="variableScope"/>
        <result column="default_value" property="defaultValue"/>
        <result column="config" property="config"/>
        <result column="script_content" property="scriptContent"/>
        <result column="description" property="description"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据模板ID查询后置处理器列表 -->
    <select id="selectByTemplateId" resultMap="BaseResultMap">
        SELECT * FROM pdm_tool_template_post_processor
        WHERE template_id = #{templateId}
        AND is_enabled = 1
        ORDER BY sort_order ASC
    </select>

    <!-- 批量插入后置处理器 -->
    <insert id="batchInsert">
        INSERT INTO pdm_tool_template_post_processor (
            template_id, processor_name, processor_type, extract_type, extract_expression,
            extract_match_no, target_variable, variable_scope, default_value, config,
            script_content, description, is_enabled, sort_order
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.templateId}, #{item.processorName}, #{item.processorType}, #{item.extractType}, #{item.extractExpression},
                #{item.extractMatchNo}, #{item.targetVariable}, #{item.variableScope}, #{item.defaultValue}, #{item.config},
                #{item.scriptContent}, #{item.description}, #{item.isEnabled}, #{item.sortOrder}
            )
        </foreach>
    </insert>

</mapper>

