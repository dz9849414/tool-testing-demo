<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tooltestingdemo.mapper.protocol.ProtocolTemplateGroupMapper">

    <resultMap id="BaseResultMap" type="com.example.tooltestingdemo.entity.protocol.ProtocolTemplateGroup">
        <id column="id" property="id"/>
        <result column="protocol_template_id" property="protocolTemplateId"/>
        <result column="group_name" property="groupName"/>
        <result column="params_config" property="paramsConfig"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>

        <result column="create_id" property="createId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_id" property="updateId"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="deleted_by" property="deletedBy"/>
        <result column="deleted_time" property="deletedTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, protocol_template_id, group_name, params_config,
        create_id, create_time, update_id, update_time, is_deleted, deleted_by, deleted_time
    </sql>

</mapper>

