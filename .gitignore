# ======================================
# Spring Boot 项目通用 .gitignore
# ======================================

# 1. Maven/Gradle 构建目录
target/
build/
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# 2. 依赖包缓存
.mvn/
!mvnw
!mvnw.cmd
!/.mvn/wrapper/maven-wrapper.jar

# 3. IDE 配置文件
### IntelliJ IDEA ###
.idea/
*.iws
*.iml
*.ipr

### Eclipse ###
.classpath
.project
.settings/
.bin/

### VS Code ###
.vscode/
*.code-workspace

# 4. 系统自动生成文件
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp

# 5. 日志文件
logs/
*.log
*.log.*

# 6. 应用配置（敏感信息）
application-dev.yml
application-prod.yml
application-local.properties
!/application.yml
!/application.properties

# 7. 其他
*.class
*.jar
*.war
*.ear
hs_err_pid*